@model GLMS.Shared.Models.Contract
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@{
    ViewData["Title"] = "Contract Details";
    var statusClass = Model.Status == GLMS.Shared.Models.ContractStatus.Active ? "bg-success" :
                      Model.Status == GLMS.Shared.Models.ContractStatus.Expired ? "bg-danger" :
                      Model.Status == GLMS.Shared.Models.ContractStatus.Draft ? "bg-secondary" : "bg-warning";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>
        Contract #@Model.Id
        <span class="badge @statusClass ms-2">@Model.Status</span>
    </h2>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">Edit</a>
        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
        {
            <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-outline-dark">⬇ Download PDF</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header bg-dark text-white">Contract Information</div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">
                <a asp-controller="Clients" asp-action="Details" asp-route-id="@Model.ClientId">
                    @Model.Client?.Name
                </a>
            </dd>
            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("dd MMMM yyyy")</dd>
            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("dd MMMM yyyy")</dd>
            <dt class="col-sm-3">Service Level</dt>
            <dd class="col-sm-9">@Model.ServiceLevel</dd>
            <dt class="col-sm-3">Signed Agreement</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.SignedAgreementFileName))
                {
                    <span>@Model.SignedAgreementFileName</span>
                }
                else
                {

                    <span class="text-muted">Not uploaded</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h4>🔧 Service Requests (@Model.ServiceRequests.Count)</h4>
    @if (Model.CanCreateServiceRequest)
    {
        <a asp-controller="ServiceRequests" asp-action="Create"
           asp-route-contractId="@Model.Id" class="btn btn-sm btn-outline-success">
            ➕ New Request
        </a>
    }
    else
    {
        <span class="badge bg-danger">No new requests — contract is @Model.Status</span>
    }
</div>

<table class="table table-sm table-bordered">
    <thead class="table-secondary">
        <tr>
            <th>#</th>
            <th>Description</th>
            <th>Cost (USD)</th>
            <th>Cost (ZAR)</th>
            <th>Status</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var sr in Model.ServiceRequests)
        {
            <tr>
                <td>@sr.Id</td>
                <td>@sr.Description</td>
                <td class="text-end">$@sr.CostUsd.ToString("N2")</td>
                <td class="text-end">R @sr.CostZar.ToString("N2")</td>
                <td><span class="badge bg-info text-dark">@sr.Status</span></td>
                <td>@sr.CreatedOn.ToString("dd MMM yyyy")</td>
            </tr>
        }
    </tbody>
</table>
