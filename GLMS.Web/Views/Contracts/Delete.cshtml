@model GLMS.Web.Models.Contract
@{
    ViewData["Title"] = "Delete Contract";
}

<h2 class="text-danger"> Delete Contract</h2>
<hr />
<div class="alert alert-warning">
    Are you sure you want to delete Contract #@Model.Id for <strong>@Model.Client?.Name</strong>?
    This will also delete the signed agreement file from the server.
</div>

<dl class="row">
    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Client?.Name</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Service Level</dt>
    <dd class="col-sm-9">@Model.ServiceLevel</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
</form>
