@model GLMS.Web.Models.ViewModels.ContractFormViewModel
@{
    ViewData["Title"] = "New Contract";
}

<h2> New Contract</h2>
<hr />

<div class="row">
    <div class="col-md-7">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="ClientId" class="form-label">Client</label>
                <select asp-for="ClientId" asp-items="Model.ClientList" class="form-select">
                    <option value="">— Select a Client —</option>
                </select>
                <span asp-validation-for="ClientId" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status"
                        asp-items="Html.GetEnumSelectList<GLMS.Shared.Models.ContractStatus>()"
                        class="form-select"></select>
            </div>

            <div class="mb-3">
                <label asp-for="ServiceLevel" class="form-label"></label>
                <input asp-for="ServiceLevel" class="form-control"
                       placeholder="e.g. Priority 1 — 4-hour response" />
                <span asp-validation-for="ServiceLevel" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SignedAgreement" class="form-label">
                    Signed Agreement <span class="text-danger">*</span>
                    <small class="text-muted">(PDF only, max 10 MB)</small>
                </label>
                <input asp-for="SignedAgreement" type="file" accept=".pdf" class="form-control" />
                <span asp-validation-for="SignedAgreement" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Create Contract</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
