@model GLMS.Shared.Models.DTOs.DashboardDto;
@{
    ViewData["Title"] = "Dashboard";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📊 Dashboard</h2>
    <span class="badge bg-success fs-6">SOA — API Connected</span>
</div>
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary h-100">
            <div class="card-body">
                <h5 class="card-title">Clients</h5>
                <p class="display-4 fw-bold">@Model.TotalClients</p>
                <a asp-controller="Clients" asp-action="Index" class="text-white small">View all →</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success h-100">
            <div class="card-body">
                <h5 class="card-title">Active Contracts</h5>
                <p class="display-4 fw-bold">@Model.ActiveContracts</p>
                <small>@Model.TotalContracts total | @Model.ExpiredContracts expired</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning h-100">
            <div class="card-body">
                <h5 class="card-title">Pending Requests</h5>
                <p class="display-4 fw-bold">@Model.PendingRequests</p>
                <small>@Model.TotalServiceRequests total service requests</small>
            </div>
        </div>
    </div>
</div>
<div class="row g-3 mb-4">
    <div class="col-md-4"><a asp-controller="Clients" asp-action="Create" class="btn btn-outline-primary w-100">➕ New Client</a></div>
    <div class="col-md-4"><a asp-controller="Contracts" asp-action="Create" class="btn btn-outline-success w-100">📄 New Contract</a></div>
    <div class="col-md-4"><a asp-controller="ServiceRequests" asp-action="Create" class="btn btn-outline-warning w-100">🔧 New Service Request</a></div>
</div>
<div class="alert alert-info small">
    <strong>Architecture note:</strong> All data is fetched from <code>GET /api/dashboard</code> via HttpClient.
    This MVC app has no direct database connection. &nbsp;
    <a href="http://localhost:8080/swagger" target="_blank">View Swagger API Docs →</a>
</div>
