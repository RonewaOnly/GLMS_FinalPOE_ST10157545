@model GLMS.Web.Models.ServiceRequest
@{
    ViewData["Title"] = "Service Request Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2> Service Request #@Model.Id</h2>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header bg-dark text-white">Request Details</div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Contract</dt>
            <dd class="col-sm-9">
                <a asp-controller="Contracts" asp-action="Details" asp-route-id="@Model.ContractId">
                    #@Model.ContractId — @Model.Contract?.Client?.Name
                </a>
            </dd>
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>
            <dt class="col-sm-3">Cost (USD)</dt>
            <dd class="col-sm-9">$@Model.CostUsd.ToString("N2")</dd>
            <dt class="col-sm-3">Cost (ZAR)</dt>
            <dd class="col-sm-9 fw-bold text-success">R @Model.CostZar.ToString("N2")</dd>
            <dt class="col-sm-3">Exchange Rate Used</dt>
            <dd class="col-sm-9">@Model.ExchangeRateUsed.ToString("N4") (USD/ZAR at time of creation)</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge bg-info text-dark">@Model.Status</span></dd>
            <dt class="col-sm-3">Created On</dt>
            <dd class="col-sm-9">@Model.CreatedOn.ToString("dd MMMM yyyy HH:mm") UTC</dd>
        </dl>
    </div>
</div>
