@model GLMS.Shared.Models.DTOs.LoginRequest
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>GLMS — Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-dark d-flex align-items-center justify-content-center" style="min-height:100vh;">
    <div class="card shadow-lg" style="width:380px;">
        <div class="card-header bg-dark text-white text-center py-4">
            <h3 class="mb-0"> GLMS</h3>
            <small class="text-muted">Global Logistics Management System</small>
        </div>
        <div class="card-body p-4">
            <h5 class="mb-4 text-center">Sign In</h5>
            <form asp-controller="Auth" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-semibold">Username</label>
                    <input asp-for="Username" class="form-control" placeholder="admin" />
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                </div>
                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">Login</button>
                </div>
            </form>
            <p class="text-center text-muted small mt-3">Default: <code>admin</code> / <code>Admin@1234</code></p>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
